# ==============================================================================
# AGENTE MAX - TEMPLATE DE CONFIGURAÇÃO (.env.example)
#
# INSTRUÇÕES:
# 1. Copie este arquivo e salve como '.env' no mesmo diretório:
#    cp .env.example .env
# 2. Preencha as variáveis de ambiente necessárias no arquivo '.env'.
# 3. NUNCA envie o arquivo '.env' para o repositório Git ou GitHub (ele já está
#    listado no arquivo .gitignore para sua segurança).
# ==============================================================================

# ------------------------------------------------------------------------------
# Configurações do Servidor & API (FastAPI)
# ------------------------------------------------------------------------------
APP_NAME="Agente MAX"
DEBUG=false
HOST="0.0.0.0"
PORT=8000

# Chave secreta para assinatura dos tokens JWT.
# IMPORTANTE: Altere para uma string longa e aleatória em ambiente de produção!
# Dica de geração: openssl rand -hex 32
JWT_SECRET_KEY="SUA_CHAVE_SUPER_SECRETA_E_LONGA_DEVE_SER_MUDADA_EM_PRODUCAO"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# URL de Conexão com o Banco de Dados (SQLite por padrão)
DATABASE_URL="sqlite+aiosqlite:///./secure_app.db"

# Origens permitidas para CORS (separe por vírgula se houver mais de uma)
ALLOWED_ORIGINS="http://localhost:3000,https://seuapp.com"

# ------------------------------------------------------------------------------
# Configuração Global de LLM (Provedores Gratuitos/Free)
# ------------------------------------------------------------------------------
# Provedor ativo. Opções válidas: openrouter | gemini | groq | mistral | ollama-cloud | ollama
LLM_PROVIDER="openrouter"

# (Opcional) Modelo específico que sobrescreve o padrão do provedor.
# Rode 'python -m src.cli models' para listar as opções disponíveis.
LLM_MODEL=""

# DICA DE ROTACIONAMENTO DE CHAVES:
# Você pode adicionar múltiplas chaves separadas por vírgula para tolerância a falhas.
# O Agente MAX rotacionará as chaves automaticamente se receber erro de limite (429).
# Exemplo: GEMINI_API_KEY="chave_A,chave_B,chave_C"

# ------------------------------------------------------------------------------
# Configurações por Provedor
# ------------------------------------------------------------------------------

# --- OpenRouter ---
# Obtenha sua chave grátis em: https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="qwen/qwen3-coder:free"

# --- Groq ---
# Obtenha sua chave grátis em: https://console.groq.com
GROQ_API_KEY=""

# --- Google Gemini ---
# Obtenha sua chave grátis em: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# --- Mistral ---
# Obtenha sua chave grátis em: https://console.mistral.ai
MISTRAL_API_KEY=""

# --- Ollama Cloud (Online & Gratuito) ---
# Obtenha sua chave grátis em: https://ollama.com/settings/keys
# Modelos disponíveis: https://ollama.com/search?c=cloud (ex.: qwen3-coder:480b-cloud)
OLLAMA_API_KEY=""

# --- Ollama Local (100% Offline & Sem Chave de API) ---
# Instalação: https://ollama.com
# Execute localmente 'ollama serve' e baixe o modelo desejado (ex.: 'ollama pull qwen2.5-coder')
OLLAMA_HOST="http://localhost:11434"
